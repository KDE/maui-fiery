#: src/views/widgets/SettingsDialog.qml:13
#, kde-format
msgid "Navigation"
msgstr "Navigace"

#: src/views/widgets/SettingsDialog.qml:14
#, kde-format
msgid "Configure the app basic navigation features."
msgstr "Nastavte základní navigační funkce aplikace."

#: src/views/widgets/SettingsDialog.qml:19
#, kde-format
msgid "Restore Session"
msgstr "Obnovit sezení"

#: src/views/widgets/SettingsDialog.qml:20
#, kde-format
msgid "Open previous tabs."
msgstr "Otevřít předchozí karty."

#: src/views/widgets/SettingsDialog.qml:33
#, kde-format
msgid "Switch to Tab"
msgstr "Přepnout na kartu"

#: src/views/widgets/SettingsDialog.qml:34
#, kde-format
msgid "When opening a new link jump to the new tab."
msgstr "Při otevření nového odkazu se stránka otevře v nové kartě."

#: src/views/widgets/SettingsDialog.qml:47
#, kde-format
msgid "Auto Load Images"
msgstr "Automatické načítání obrázků"

#: src/views/widgets/SettingsDialog.qml:48
#, kde-format
msgid "Automatically loads images on web pages."
msgstr "Automaticky načítá obrázky na webových stránkách."

#: src/views/widgets/SettingsDialog.qml:61
#, kde-format
msgid "Hyperlink Auditing"
msgstr "Kontrola hypertextových odkazů"

#: src/views/widgets/SettingsDialog.qml:62
#, kde-format
msgid "Enables support for the ping attribute for hyperlinks."
msgstr "Zapíná podporu atributu ping pro hypertextové odkazy."

#: src/views/widgets/SettingsDialog.qml:76
#: src/views/widgets/SettingsDialog.qml:106
#, kde-format
msgid "General"
msgstr "Obecné"

#: src/views/widgets/SettingsDialog.qml:77
#, kde-format
msgid "Configure global preferences."
msgstr "Nastavit globální předvolby."

#: src/views/widgets/SettingsDialog.qml:89
#: src/views/widgets/SettingsDialog.qml:173
#, kde-format
msgid "Features"
msgstr "Vlastnosti"

#: src/views/widgets/SettingsDialog.qml:90
#, kde-format
msgid "Configure the browser plugins and features."
msgstr "Nastavení modulů a funkcí prohlížeče."

#: src/views/widgets/SettingsDialog.qml:110
#, kde-format
msgid "Home Page"
msgstr "Domovská stránka"

#: src/views/widgets/SettingsDialog.qml:111
#, kde-format
msgid "Page to load initially and default."
msgstr "Výchozí stránka, která se načte na začátku."

#: src/views/widgets/SettingsDialog.qml:122
#, kde-format
msgid "Search Engine"
msgstr "Vyhledávací stroj"

#: src/views/widgets/SettingsDialog.qml:123
#, kde-format
msgid "Engine to be use for default searching content."
msgstr "Vyhledávač, který se použije pro standardní vyhledávání obsahu."

#: src/views/widgets/SettingsDialog.qml:138
#, kde-format
msgid "Downloads Path"
msgstr "Cesta k adresáři se staženými soubory"

#: src/views/widgets/SettingsDialog.qml:139
#, kde-format
msgid "Pick a path where files will be saved."
msgstr "Vyberte umístění, kam se mají ukládat soubory."

#: src/views/widgets/SettingsDialog.qml:150
#, kde-format
msgid "Auto Save"
msgstr "Automatické ukládání"

#: src/views/widgets/SettingsDialog.qml:151
#, kde-format
msgid "Download files without asking."
msgstr "Stahovat soubory bez dotazování."

#: src/views/widgets/SettingsDialog.qml:179
#, kde-format
msgid "Accelerated 2D Canvas"
msgstr "Akcelerované 2D plátno"

#: src/views/widgets/SettingsDialog.qml:180
#, kde-format
msgid ""
"Specifies whether the HTML 5 2D canvas should be an OpenGL framebuffer. This "
"makes many painting operations faster, but slows down pixel access."
msgstr ""
"Určuje, zda má být 2D plátno HTML5 vyrovnávací pamětí OpenGL. Tím se zrychlí "
"mnoho operací vykreslování, ale zpomalí se přístup k pixelům."

#: src/views/widgets/SettingsDialog.qml:193
#, kde-format
msgid "PDF Viewer"
msgstr "Prohlížeč PDF"

#: src/views/widgets/SettingsDialog.qml:194
#, kde-format
msgid ""
"PDF documents will be opened in the internal PDF viewer instead of being "
"downloaded."
msgstr ""
"Dokumenty ve formátu PDF se budou otevírat ve vestavěném prohlížeči PDF, "
"místo toho, aby se stahovaly."

#: src/views/widgets/SettingsDialog.qml:207
#, kde-format
msgid "Plugins Enabled"
msgstr "Moduly povoleny"

#: src/views/widgets/SettingsDialog.qml:208
#, kde-format
msgid "Enables support for Pepper plugins, such as the Flash player."
msgstr "Zapíná podporu pluginů Pepper, jako je například Flash Player."

#: src/views/widgets/SettingsDialog.qml:224
#: src/views/widgets/SettingsDialog.qml:241
#, kde-format
msgid "JavaScript"
msgstr "JavaScript"

#: src/views/widgets/SettingsDialog.qml:225
#, kde-format
msgid "Configure JavaScript behaviour."
msgstr "Nastavit chování JavaScriptu."

#: src/views/widgets/SettingsDialog.qml:247
#, kde-format
msgid "Javascript Enabled"
msgstr "JavaScript povolen"

#: src/views/widgets/SettingsDialog.qml:248
#, kde-format
msgid "Enables the running of JavaScript programs."
msgstr "Umožňuje spouštění programů v jazyce JavaScript."

#: src/views/widgets/SettingsDialog.qml:261
#, kde-format
msgid "Javascript Can Access Clipboard"
msgstr "Javascript má přístup ke schránce"

#: src/views/widgets/SettingsDialog.qml:262
#, kde-format
msgid "Allows JavaScript programs to read from or write to the clipboard."
msgstr ""
"Umožňuje programům v jazyce JavaScript číst ze schránky nebo do ní zapisovat."

#: src/views/widgets/SettingsDialog.qml:275
#, kde-format
msgid "Javascript Can Paste"
msgstr "Javascript umožňuje vkládat"

#: src/views/widgets/SettingsDialog.qml:276
#, kde-format
msgid "Enables JavaScript execCommand(paste)."
msgstr "Povoluje funkci JavaScriptu execCommand(vložit)."

#: src/views/widgets/SettingsDialog.qml:289
#, kde-format
msgid "Allow Window Activation From JavaScript"
msgstr "Povolit aktivaci oken z JavaScriptu"

#: src/views/widgets/SettingsDialog.qml:290
#, kde-format
msgid "Allows the window.focus() method in JavaScript."
msgstr "Umožňuje použití metody window.focus() v jazyce JavaScript."

#: src/views/widgets/SettingsDialog.qml:307
#: src/views/widgets/SettingsDialog.qml:323
#, kde-format
msgid "Security & Privacy"
msgstr "Zabezpečení a soukromí"

#: src/views/widgets/SettingsDialog.qml:308
#, kde-format
msgid ""
"Configure the look and feel of the editor. The settings are applied globally"
msgstr "Nastavte vzhled a chování editoru. Nastavení se použije globálně"

#: src/views/widgets/SettingsDialog.qml:329
#, kde-format
msgid "Allow Geolocation On Insecure Origins"
msgstr "Povolit geolokaci u nezabezpečených zdrojů"

#: src/views/widgets/SettingsDialog.qml:330
#, kde-format
msgid ""
"Only secure origins such as HTTPS have been able to request Geolocation "
"features."
msgstr ""
"O funkce geolokace mohou žádat pouze zabezpečené zdroje, jako je například "
"HTTPS."

#: src/views/widgets/SettingsDialog.qml:343
#, kde-format
msgid "Allow Running Insecure Content"
msgstr "Povolit spouštění nezabezpečeného obsahu"

#: src/views/widgets/SettingsDialog.qml:344
#, kde-format
msgid ""
"By default, HTTPS pages cannot run JavaScript, CSS, plugins or web-sockets "
"from HTTP URLs."
msgstr ""
"Ve výchozím nastavení nelze na stránkách HTTPS spouštět skripty JavaScript, "
"soubory CSS, pluginy ani webové sokety z adres URL protokolu HTTP."

#: src/views/widgets/SettingsDialog.qml:358
#, kde-format
msgid "DNS Prefetch Enabled"
msgstr "Přednačítání DNS povoleno"

#: src/views/widgets/SettingsDialog.qml:359
#, kde-format
msgid ""
"Enables speculative prefetching of DNS records for HTML links before they "
"are activated."
msgstr ""
"Umožňuje preventivní načítání záznamů DNS pro odkazy v HTML ještě před "
"jejich aktivací."

#: src/views/widgets/SettingsDialog.qml:372
#, kde-format
msgid "Local Content Can Access File Urls"
msgstr "Místní obsah má přístup k URL adresám souborů"

#: src/views/widgets/SettingsDialog.qml:373
#, kde-format
msgid "Allows locally loaded documents to access other local URLs."
msgstr ""
"Umožňuje místně načteným dokumentům přistupovat k jiným místním adresám URL."

#: src/views/widgets/SettingsDialog.qml:386
#, kde-format
msgid "Local Content Can Access Remote Urls"
msgstr "Místní obsah může přistupovat ke vzdáleným URL adresám"

#: src/views/widgets/SettingsDialog.qml:387
#, kde-format
msgid "Allows locally loaded documents to access remote URLs."
msgstr ""
"Umožňuje lokálně načteným dokumentům přistupovat ke vzdáleným URL adresám."

#: src/views/widgets/SettingsDialog.qml:400
#, kde-format
msgid "Local Storage"
msgstr "Lokální úložiště"

#: src/views/widgets/SettingsDialog.qml:401
#, kde-format
msgid "Enables support for the HTML 5 local storage feature."
msgstr "Povoluje podporu místního úložiště, vlastnosti HTML 5."

#: src/views/widgets/SettingsDialog.qml:414
#, kde-format
msgid "WebRTC Public Interfaces Only"
msgstr "Pouze veřejná rozhraní WebRTC"

#: src/views/widgets/SettingsDialog.qml:415
#, kde-format
msgid ""
"Limits WebRTC to public IP addresses only. When disabled WebRTC may also use "
"local network IP addresses, but remote hosts can also see your local network "
"IP address."
msgstr ""
"Omezuje WebRTC pouze na veřejné IP adresy. Je-li tato funkce vypnutá, může "
"WebRTC využívat i IP adresy v místní síti, ale vzdálené servery pak mohou "
"vidět i vaši IP adresu v místní síti."
